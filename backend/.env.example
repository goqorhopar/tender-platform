# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ============================================================================
# DATABASE SETTINGS
# ============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=tender_user
POSTGRES_PASSWORD=tender_password
POSTGRES_DB=tender_platform

# ============================================================================
# REDIS SETTINGS
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================================================
# JWT SETTINGS
# ============================================================================
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# EMAIL SETTINGS
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@tender-platform.com
FIRST_SUPERUSER=admin@tender-platform.com
FIRST_SUPERUSER_PASSWORD=AdminPassword123!

# ============================================================================
# STORAGE SETTINGS
# ============================================================================
STORAGE_TYPE=local
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=10485760

# S3 Settings (optional)
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================================================
# AI/ML INTEGRATION
# ============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GEMINI_API_KEY=

# ============================================================================
# TELEGRAM BOT
# ============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ============================================================================
# LOGGING SETTINGS
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=/app/logs
